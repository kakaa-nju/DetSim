# Ignore everything by default
*
*.*

# Source files
!*.c
!*.cpp
!*.h
!*.json
!*.md
!*.rst
!*.sh
!*.py
!LICENSE

# Build system
!Makefile
!CMakeLists.txt
!.clang-format

# Git
!.gitignore

# Source directories
!src/
!src/core/
!src/core/*
!src/subsys/
!src/subsys/*
!src/utils/
!src/utils/*
!src/ui/
!src/ui/*

# Perf benchmarks
!perf/
!perf/*

# Third party
!third_party/
!third_party/**

# Tests
!tests/

# Scripts
!scripts/
!scripts/*

# Docs
!docs/
!docs/**

# Build artifacts (ignored even with wildcards above)
tracer
*.o
*.d
*.so

# Runtime directories
build/
mappings/
memory/
filesystem/
tstate/
sstate/

# IDE
.cache/
.vscode/
.idea/

# Debug
core.*
*.log

# tools
!tools/
!tools/**

# examples
!examples/
!examples/**

# Ignore build artifacts in examples
examples/**/*.o
examples/**/*.so
examples/**/*.a
examples/**/compile_commands.json
examples/**/__pycache__/
examples/**/*.pyc

# Ignore compiled binaries (match specific files)
/examples/raft/raft/raft
/examples/raft/raft/raft_dynamic
/examples/bakery/bakery
/examples/bakery/bakery_mp
/examples/brk/brk
/examples/bt/bt
/examples/cast_test/cast_test
/examples/complex/complex
/examples/devices/devices
/examples/expr_test/expr_test
/examples/fs/fs
/examples/loop/loop
/examples/loop/loop3
/examples/loop_inf/loop_inf
/examples/malloc/malloc
/examples/member/member
/examples/pipe/pipe
/examples/poll/poll
/examples/simple_complex/simple_complex
/examples/write/write
/examples/raft/plugins/check.so
/examples/raft/plugins/choose.so
